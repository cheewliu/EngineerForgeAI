---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" description="This page does not exist.">
  <div class="not-found">
    <div class="not-found__glitch" aria-hidden="true">
      <span class="not-found__code" data-text="404">404</span>
    </div>
    <h1 class="not-found__title">Lost in the context window</h1>
    <p class="not-found__desc">
      This page either never existed or drifted out of scope.
      Let's get you back on track.
    </p>
    <div class="not-found__actions">
      <a href="/" class="not-found__btn not-found__btn--primary">Back to posts</a>
      <a href="/tags" class="not-found__btn not-found__btn--secondary">Browse topics</a>
    </div>
  </div>
</BaseLayout>

<style>
.not-found {
  padding: 8rem 0 6rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.not-found__glitch {
  position: relative;
  margin-bottom: 2rem;
}

.not-found__code {
  font-size: clamp(6rem, 15vw, 10rem);
  font-weight: 900;
  line-height: 1;
  font-family: var(--font);
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  background-size: 200% auto;
  animation: gradientShift 4s ease infinite;
  position: relative;
}

.not-found__code::before,
.not-found__code::after {
  content: attr(data-text);
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.not-found__code::before {
  animation: glitch-1 3s infinite linear;
  clip-path: inset(40% 0 20% 0);
  opacity: 0.6;
}

.not-found__code::after {
  animation: glitch-2 3s infinite linear;
  clip-path: inset(60% 0 0% 0);
  opacity: 0.6;
}

@keyframes glitch-1 {
  0%, 100% { transform: translateX(0); }
  20%      { transform: translateX(-3px); }
  40%      { transform: translateX(3px); }
  60%      { transform: translateX(-2px); }
  80%      { transform: translateX(2px); }
}

@keyframes glitch-2 {
  0%, 100% { transform: translateX(0); }
  25%      { transform: translateX(4px); }
  50%      { transform: translateX(-4px); }
  75%      { transform: translateX(2px); }
}

.not-found__title {
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  margin-bottom: 0.85rem;
  color: var(--text);
}

.not-found__desc {
  color: var(--text-3);
  font-size: 1rem;
  line-height: 1.7;
  max-width: 420px;
  margin-bottom: 2.5rem;
}

.not-found__actions {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  justify-content: center;
}

.not-found__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.7rem 1.75rem;
  border-radius: 10px;
  font-size: 0.875rem;
  font-weight: 700;
  transition: all 0.2s var(--ease);
}

.not-found__btn--primary {
  background: var(--gradient);
  color: #fff;
}
.not-found__btn--primary:hover {
  opacity: 0.85;
  transform: translateY(-1px);
  box-shadow: 0 4px 20px rgba(139, 92, 246, 0.3);
}

.not-found__btn--secondary {
  background: var(--bg-card);
  color: var(--text-2);
  border: 1px solid var(--border);
}
.not-found__btn--secondary:hover {
  color: var(--text);
  border-color: var(--border-hover);
  transform: translateY(-1px);
}

@media (max-width: 480px) {
  .not-found { padding: 4rem 0 3rem; }
  .not-found__actions { flex-direction: column; }
}
</style>
